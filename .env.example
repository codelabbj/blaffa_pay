# =============================================================================
# Blaffa Pay — configuration (.env.local en dev, variables Railway/Vercel en prod)
# Copier vers .env.local : cp .env.example .env.local
# =============================================================================

# --- API backend (connect_pro / yapson) ---
# Avec ou sans slash final — normalisé automatiquement.
NEXT_PUBLIC_API_BASE_URL=https://connect.yapson.net
NEXT_PUBLIC_API_TOKEN=

# WebSocket admin (optionnel, feature websocket)
NEXT_PUBLIC_WS_URL=wss://connect.yapson.net/ws/payment/

# --- Branding (white-label) — défauts = Blaffa Pay ---
NEXT_PUBLIC_APP_NAME=Blaffa Pay
NEXT_PUBLIC_APP_TAGLINE=Admin Dashboard
NEXT_PUBLIC_APP_LOGO=/logo.png
# NEXT_PUBLIC_APP_SHORT_NAME=BP
# NEXT_PUBLIC_APP_COPYRIGHT=© 2026 Mon Client. Tous droits réservés.

# =============================================================================
# Feature flags — absent ou "true" = activé (défaut)
# Mettre "false" pour masquer une section du menu et bloquer la route
# =============================================================================

NEXT_PUBLIC_FEATURE_DASHBOARD=true
NEXT_PUBLIC_FEATURE_USERS=true
NEXT_PUBLIC_FEATURE_TRANSACTIONS=true
NEXT_PUBLIC_FEATURE_BULK_DEPOSIT_NETWORKS=true
NEXT_PUBLIC_FEATURE_DEVICE_AUTHORIZATIONS=true
NEXT_PUBLIC_FEATURE_AGGREGATORS=true
NEXT_PUBLIC_FEATURE_COUNTRY=true
NEXT_PUBLIC_FEATURE_NETWORK=true
NEXT_PUBLIC_FEATURE_NETWORK_CONFIG=true
NEXT_PUBLIC_FEATURE_PHONE_NUMBERS=true
NEXT_PUBLIC_FEATURE_DEVICES=true
NEXT_PUBLIC_FEATURE_SMS_LOGS=true
NEXT_PUBLIC_FEATURE_FCM_LOGS=true
NEXT_PUBLIC_FEATURE_PARTNER=true
NEXT_PUBLIC_FEATURE_PARTNER_TRANSFERS=true
NEXT_PUBLIC_FEATURE_PLATFORMS=true
NEXT_PUBLIC_FEATURE_PERMISSIONS=true
NEXT_PUBLIC_FEATURE_BETTING_TRANSACTIONS=true
NEXT_PUBLIC_FEATURE_API_CONFIG=true
NEXT_PUBLIC_FEATURE_PARTNER_PERMISSIONS_SUMMARY=true
NEXT_PUBLIC_FEATURE_TOPUP=true
NEXT_PUBLIC_FEATURE_EARNING_MANAGEMENT=true
NEXT_PUBLIC_FEATURE_WAVE_BUSINESS=true
NEXT_PUBLIC_FEATURE_MOMO_PAY=true
NEXT_PUBLIC_FEATURE_TRANSACTION_LOGS=true
NEXT_PUBLIC_FEATURE_REMOTE_COMMAND=true
NEXT_PUBLIC_FEATURE_WEBSOCKET=true
NEXT_PUBLIC_FEATURE_PROFILE=true
